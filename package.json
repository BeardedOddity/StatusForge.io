{
  "name": "statusforge.io",
  "version": "1.0.0",
  "description": "StatusForge.io Rich Presence Engine",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --universal",
    "build:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.bearddoddity.statusforge.io",
    "productName": "StatusForge.io",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "presence*",
      "Dashboard.html",
      "Logic.js",
      "layouts/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1"
  }
}
